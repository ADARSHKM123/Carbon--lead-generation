# ─── AI Provider ──────────────────────────────────────────────
# Set AI_PROVIDER to "anthropic" or "deepseek" to switch models
AI_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Meta Graph API (for Instagram hashtag/business discovery)
# Requires an Instagram Business/Creator account connected to a Facebook Page.
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# HikerAPI (third-party Instagram scraping) — optional fallback if user
# doesn't provide their own key from the IG Scraper page.
# Get a key at https://hikerapi.com
HIKER_API_KEY=
# ──────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/carbon_outreach

# Redis (for Celery outreach queue)
REDIS_URL=redis://localhost:6379

# Email outreach (SendGrid)
SENDGRID_API_KEY=SG....

# Email outreach (SMTP alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# Outreach safety settings
OUTREACH_MIN_DELAY=30
OUTREACH_MAX_DELAY=120
